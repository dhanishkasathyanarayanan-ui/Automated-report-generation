from reportlab.platypus import SimpleDocTemplate, Paragraph
from reportlab.lib.styles import getSampleStyleSheet
import csv

# Read data
marks = []
with open("data.csv") as f:
    reader = csv.reader(f)
    next(reader)
    for row in reader:
        marks.append(int(row[1]))

# Analysis
avg = sum(marks) / len(marks)
high = max(marks)
low = min(marks)

# Create PDF
doc = SimpleDocTemplate("Report.pdf")
styles = getSampleStyleSheet()

content = []
content.append(Paragraph("Student Report", styles['Title']))
content.append(Paragraph(f"Average: {avg:.2f}", styles['Normal']))
content.append(Paragraph(f"Highest: {high}", styles['Normal']))
content.append(Paragraph(f"Lowest: {low}", styles['Normal']))

doc.build(content)

print("Report Generated")
